#!/bin/bash
# =============================================================================
# ATLAZES OS - Main CLI Tool
# Usage: atlazes <command> [options]
# =============================================================================

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

ATLAZES_VERSION="1.0.0"
ATLAZES_MODE_FILE="/var/lib/atlazes/current-mode"
ATLAZES_STATE_DIR="/var/lib/atlazes"

# ─── Helpers ──────────────────────────────────────────────────────────────────
log()     { echo -e "${GREEN}[+]${NC} $*"; }
warn()    { echo -e "${YELLOW}[!]${NC} $*"; }
error()   { echo -e "${RED}[✗]${NC} $*" >&2; exit 1; }
info()    { echo -e "${CYAN}[i]${NC} $*"; }
ok()      { echo -e "  ${GREEN}✓${NC} $*"; }
fail()    { echo -e "  ${RED}✗${NC} $*"; }
maybe()   { echo -e "  ${YELLOW}~${NC} $*"; }

need_root() {
    [[ $EUID -eq 0 ]] || error "This command requires root. Run: sudo atlazes $*"
}

get_mode() {
    [[ -f "$ATLAZES_MODE_FILE" ]] && cat "$ATLAZES_MODE_FILE" || echo "normal"
}

banner() {
    echo -e "${BLUE}${BOLD}"
    echo "  ╔══════════════════════════════════════════╗"
    echo "  ║           ATLAZES OS TOOLS               ║"
    printf "  ║  Version %-32s║\n" "${ATLAZES_VERSION}  Mode: $(get_mode)"
    echo "  ╚══════════════════════════════════════════╝"
    echo -e "${NC}"
}

# ─── COMMAND: status ──────────────────────────────────────────────────────────
cmd_status() {
    banner
    local current_mode
    current_mode=$(get_mode)

    echo -e "${CYAN}${BOLD}── Security Status ──────────────────────────────${NC}"
    echo ""

    # Firewall
    # BUG FIX: Use pkexec or check without sudo to avoid password prompt for non-root
    local ufw_status
    ufw_status=$(ufw status 2>/dev/null || true)
    if echo "$ufw_status" | grep -q "Status: active"; then
        ok "Firewall (UFW): Active"
    else
        fail "Firewall (UFW): Inactive — run: sudo ufw enable"
    fi

    # AppArmor
    if systemctl is-active apparmor &>/dev/null; then
        local enforced complain
        enforced=$(aa-status 2>/dev/null | grep "profiles are in enforce mode" | awk '{print $1}' || echo "?")
        complain=$(aa-status 2>/dev/null | grep "profiles are in complain mode" | awk '{print $1}' || echo "?")
        ok "AppArmor: Active (${enforced} enforced, ${complain} complain)"
    else
        fail "AppArmor: Inactive"
    fi

    # dnscrypt-proxy
    if systemctl is-active dnscrypt-proxy &>/dev/null; then
        ok "Encrypted DNS (dnscrypt-proxy): Active"
    else
        maybe "Encrypted DNS: Inactive (optional)"
    fi

    # Fail2ban
    if systemctl is-active fail2ban &>/dev/null; then
        ok "Fail2ban: Active"
    else
        maybe "Fail2ban: Inactive"
    fi

    # ClamAV
    if systemctl is-active clamav-daemon &>/dev/null; then
        ok "ClamAV: Active"
    else
        maybe "ClamAV: Inactive (run: sudo systemctl start clamav-daemon)"
    fi

    # Tor
    if systemctl is-active tor &>/dev/null; then
        ok "Tor: Active (SOCKS5 on 127.0.0.1:9050)"
    else
        info "Tor: Inactive (optional — run: sudo atlazes tor start)"
    fi

    echo ""
    echo -e "${CYAN}${BOLD}── Privacy Status ───────────────────────────────${NC}"
    echo ""

    # MAC randomization
    if grep -q "wifi.cloned-mac-address=random" /etc/NetworkManager/conf.d/*.conf 2>/dev/null; then
        ok "MAC Randomization: Enabled (local network only — no effect on internet tracking)"
    else
        maybe "MAC Randomization: Not configured"
    fi

    # DNS
    local dns_server
    dns_server=$(grep "^nameserver" /etc/resolv.conf 2>/dev/null | head -1 | awk '{print $2}' || echo "unknown")
    if [[ "$dns_server" == "127.0.0.1" ]]; then
        ok "DNS: Encrypted in transit (127.0.0.1 → dnscrypt-proxy → Quad9/Cloudflare)"
    else
        maybe "DNS: ${dns_server} (queries not encrypted by dnscrypt-proxy)"
    fi

    # Hosts blocking
    local blocked
    blocked=$(grep -c "^0\.0\.0\.0" /etc/hosts 2>/dev/null || echo "0")
    ok "Tracker Blocking: ${blocked} domains in /etc/hosts"

    # Kernel hardening
    local kptr
    kptr=$(sysctl -n kernel.kptr_restrict 2>/dev/null || echo "?")
    if [[ "$kptr" == "2" ]]; then
        ok "Kernel Hardening: Active (kptr_restrict=2)"
    else
        maybe "Kernel Hardening: Partial (kptr_restrict=${kptr})"
    fi

    echo ""
    echo -e "${CYAN}${BOLD}── Current Mode: ${BOLD}${current_mode^^}${NC}"
    echo ""
    case "$current_mode" in
        normal)   info "Normal mode: encrypted DNS, MAC randomization, firewall active. IP visible to websites." ;;
        private)  info "Private mode: MAC randomized, IPv6 off, DNS encrypted. IP still visible to websites." ;;
        paranoid) info "Paranoid mode: Tor routing, strict firewall. Significantly increased anonymity — not a guarantee." ;;
    esac
    echo ""
}

# ─── COMMAND: scan ────────────────────────────────────────────────────────────
cmd_scan() {
    local target="${1:-$HOME}"
    echo -e "${CYAN}${BOLD}── ClamAV Virus Scan ────────────────────────────${NC}"
    echo ""
    info "Scanning: ${target}"
    info "This may take several minutes..."
    echo ""

    if ! command -v clamscan &>/dev/null; then
        error "ClamAV not installed. Run: sudo apt install clamav"
    fi

    # Update signatures first
    if [[ $EUID -eq 0 ]]; then
        systemctl stop clamav-freshclam 2>/dev/null || true
        freshclam --quiet 2>/dev/null || warn "Signature update failed (no internet?)"
        systemctl start clamav-freshclam 2>/dev/null || true
    fi

    clamscan -r --bell -i --suppress-ok-results "$target"
    local exit_code=$?

    echo ""
    case $exit_code in
        0) ok "Scan complete: No threats found." ;;
        1) warn "Scan complete: Threats found! Review output above." ;;
        2) warn "Scan complete: Errors occurred during scan." ;;
    esac
}

# ─── COMMAND: clean ───────────────────────────────────────────────────────────
cmd_clean() {
    echo -e "${CYAN}${BOLD}── Privacy Cleanup ──────────────────────────────${NC}"
    echo ""

    # BleachBit
    if command -v bleachbit &>/dev/null; then
        info "Running BleachBit..."
        # BUG FIX: Cleaner IDs vary by BleachBit version.
        # Use --list to find available cleaners, then clean what exists.
        # firefox_esr.* was renamed to firefox.* in newer BleachBit versions.
        local available_cleaners
        available_cleaners=$(bleachbit --list 2>/dev/null || true)

        local clean_args=("system.cache" "system.tmp" "system.trash" "system.rotated_logs")

        # Add Firefox cleaner — try both names
        if echo "$available_cleaners" | grep -q "^firefox_esr\."; then
            clean_args+=("firefox_esr.cache" "firefox_esr.cookies" "firefox_esr.forms" "firefox_esr.session_restore")
        elif echo "$available_cleaners" | grep -q "^firefox\."; then
            clean_args+=("firefox.cache" "firefox.cookies" "firefox.forms" "firefox.session_restore")
        fi

        bleachbit --clean "${clean_args[@]}" 2>/dev/null || true
        ok "BleachBit cleanup done."
    else
        # Manual cleanup
        info "BleachBit not found. Running manual cleanup..."
        rm -rf "${HOME}/.cache/thumbnails/"* 2>/dev/null || true
        rm -rf "${HOME}/.local/share/recently-used.xbel" 2>/dev/null || true
        find /tmp -maxdepth 1 -user "$(id -u)" -delete 2>/dev/null || true
        ok "Manual cleanup done."
    fi

    # Clear bash history
    read -r -p "  Clear bash history? [y/N] " answer
    if [[ "${answer,,}" == "y" ]]; then
        cat /dev/null > "${HOME}/.bash_history"
        history -c
        ok "Bash history cleared."
    fi

    echo ""
    ok "Cleanup complete."
}

# ─── COMMAND: secure ──────────────────────────────────────────────────────────
cmd_secure() {
    need_root "secure"
    echo -e "${CYAN}${BOLD}── Security Hardening Check & Fix ───────────────${NC}"
    echo ""

    local issues=0

    # Check and fix UFW
    if ! ufw status | grep -q "Status: active"; then
        warn "UFW is inactive. Enabling..."
        ufw --force enable
        ok "UFW enabled."
        ((issues++))
    else
        ok "UFW: Active"
    fi

    # Check and fix AppArmor
    if ! systemctl is-active apparmor &>/dev/null; then
        warn "AppArmor is inactive. Starting..."
        systemctl start apparmor
        systemctl enable apparmor
        ok "AppArmor started."
        ((issues++))
    else
        ok "AppArmor: Active"
    fi

    # Check and fix dnscrypt-proxy
    if ! systemctl is-active dnscrypt-proxy &>/dev/null; then
        warn "dnscrypt-proxy is inactive. Starting..."
        systemctl start dnscrypt-proxy 2>/dev/null && ok "dnscrypt-proxy started." || \
            warn "dnscrypt-proxy failed to start."
        ((issues++))
    else
        ok "dnscrypt-proxy: Active"
    fi

    # Check and fix Fail2ban
    if ! systemctl is-active fail2ban &>/dev/null; then
        warn "Fail2ban is inactive. Starting..."
        systemctl start fail2ban
        ok "Fail2ban started."
        ((issues++))
    else
        ok "Fail2ban: Active"
    fi

    # Check sysctl hardening
    local kptr
    kptr=$(sysctl -n kernel.kptr_restrict 2>/dev/null || echo "0")
    if [[ "$kptr" != "2" ]]; then
        warn "Kernel hardening not fully applied. Applying..."
        sysctl -w kernel.kptr_restrict=2 2>/dev/null || true
        sysctl -w kernel.dmesg_restrict=1 2>/dev/null || true
        sysctl -w kernel.randomize_va_space=2 2>/dev/null || true
        ok "Kernel hardening applied (runtime)."
        ((issues++))
    else
        ok "Kernel hardening: Active"
    fi

    # Update ClamAV signatures
    info "Updating ClamAV signatures..."
    systemctl stop clamav-freshclam 2>/dev/null || true
    freshclam --quiet 2>/dev/null && ok "ClamAV signatures updated." || \
        warn "ClamAV update failed (no internet?)"
    systemctl start clamav-freshclam 2>/dev/null || true

    # Run rkhunter check
    info "Running rkhunter check..."
    rkhunter --check --sk --quiet 2>/dev/null && ok "rkhunter: No issues found." || \
        warn "rkhunter found potential issues. Run: sudo rkhunter --check for details."

    echo ""
    if [[ $issues -eq 0 ]]; then
        ok "All security checks passed."
    else
        warn "${issues} issue(s) were found and fixed."
    fi
}

# ─── COMMAND: sandbox ─────────────────────────────────────────────────────────
cmd_sandbox() {
    local app="${1:-}"
    shift || true

    if [[ -z "$app" ]]; then
        echo -e "${CYAN}${BOLD}── Firejail Sandbox ─────────────────────────────${NC}"
        echo ""
        echo "Usage: atlazes sandbox <application> [args...]"
        echo ""
        echo "Examples:"
        echo "  atlazes sandbox firefox"
        echo "  atlazes sandbox firefox https://example.com"
        echo "  atlazes sandbox thunderbird"
        echo "  atlazes sandbox vlc /path/to/video.mp4"
        echo "  atlazes sandbox evince document.pdf"
        echo ""
        echo "Sandboxed applications (auto-profiled):"
        if command -v firejail &>/dev/null; then
            firejail --list 2>/dev/null | head -20 || true
        else
            warn "Firejail not installed. Run: sudo apt install firejail"
        fi
        return
    fi

    if ! command -v firejail &>/dev/null; then
        error "Firejail not installed. Run: sudo apt install firejail firejail-profiles"
    fi

    info "Launching ${app} in Firejail sandbox..."

    # Check if a dedicated profile exists
    local profile_path="/etc/firejail/${app}.profile"
    if [[ -f "$profile_path" ]]; then
        info "Using profile: ${profile_path}"
        firejail --profile="$profile_path" "$app" "$@"
    else
        info "No dedicated profile found. Using default sandbox."
        firejail --private "$app" "$@"
    fi
}

# ─── COMMAND: mode ────────────────────────────────────────────────────────────
cmd_mode() {
    local target_mode="${1:-}"

    if [[ -z "$target_mode" ]]; then
        echo -e "${CYAN}${BOLD}── Privacy Modes ────────────────────────────────${NC}"
        echo ""
        local current
        current=$(get_mode)
        echo "  Current mode: ${BOLD}${current^^}${NC}"
        echo ""
        echo "  Available modes:"
        echo "    normal    - Encrypted DNS, MAC randomization, firewall. IP visible to websites."
        echo "    private   - Adds immediate MAC randomization, IPv6 off. IP still visible."
        echo "    paranoid  - Tor routing, strict firewall. Increased anonymity, not a guarantee."
        echo ""
        echo "  Usage: sudo atlazes mode <normal|private|paranoid>"
        return
    fi

    need_root "mode $target_mode"

    case "$target_mode" in
        normal)   _set_mode_normal ;;
        private)  _set_mode_private ;;
        paranoid) _set_mode_paranoid ;;
        *)
            error "Unknown mode: ${target_mode}. Use: normal | private | paranoid"
            ;;
    esac
}

_set_mode_normal() {
    echo -e "${CYAN}${BOLD}── Switching to NORMAL Mode ─────────────────────${NC}"
    echo ""

    mkdir -p "$ATLAZES_STATE_DIR"

    # Firewall: standard rules
    ufw --force reset
    ufw default deny incoming
    ufw default allow outgoing
    ufw logging off
    ufw --force enable
    ok "Firewall: standard rules"

    # DNS: use dnscrypt-proxy if available, else system default
    if systemctl is-enabled dnscrypt-proxy &>/dev/null; then
        systemctl start dnscrypt-proxy 2>/dev/null || true
        ok "DNS: encrypted (dnscrypt-proxy)"
    else
        ok "DNS: system default"
    fi

    # Stop Tor if running
    systemctl stop tor 2>/dev/null || true
    ok "Tor: stopped"

    # MAC: random per connection (already configured in NM)
    ok "MAC: random per connection"

    # Restore normal AppArmor (complain for most, enforce for browsers)
    systemctl start apparmor 2>/dev/null || true
    ok "AppArmor: standard profiles"

    echo "normal" > "$ATLAZES_MODE_FILE"
    echo ""
    ok "Mode set to: NORMAL"
    info "Encrypted DNS, MAC randomization, firewall active. IP address visible to websites."
}

_set_mode_private() {
    echo -e "${CYAN}${BOLD}── Switching to PRIVATE Mode ────────────────────${NC}"
    echo ""

    mkdir -p "$ATLAZES_STATE_DIR"

    # Firewall: deny all incoming, allow outgoing
    ufw --force reset
    ufw default deny incoming
    ufw default allow outgoing
    ufw default deny forward
    ufw logging on
    ufw --force enable
    ok "Firewall: strict (deny all incoming)"

    # DNS: force encrypted
    if systemctl is-enabled dnscrypt-proxy &>/dev/null; then
        systemctl restart dnscrypt-proxy 2>/dev/null || true
        # Restore resolv.conf to point to dnscrypt-proxy
        cat > /etc/resolv.conf << 'EOF'
# ATLAZES OS - Private Mode: Encrypted DNS
nameserver 127.0.0.1
options edns0 trust-ad
EOF
        ok "DNS: encrypted (dnscrypt-proxy)"
    else
        warn "dnscrypt-proxy not available. Install: sudo apt install dnscrypt-proxy"
    fi

    # MAC: randomize all interfaces now
    # BUG FIX: Bringing interface down/up with macchanger drops the WiFi connection
    # permanently on some drivers (especially iwlwifi). Use NetworkManager's built-in
    # MAC randomization trigger instead — reconnect to apply new MAC.
    if command -v macchanger &>/dev/null; then
        for iface in $(ip link show | grep "^[0-9]" | awk -F': ' '{print $2}' | grep -v lo | grep -v docker | grep -v veth); do
            macchanger -r "$iface" 2>/dev/null || true
        done
        ok "MAC: randomized (reconnect to network to apply)"
    else
        ok "MAC: will randomize on next connection (NetworkManager)"
    fi

    # Disable IPv6 (privacy leak vector)
    sysctl -w net.ipv6.conf.all.disable_ipv6=1 2>/dev/null || true
    sysctl -w net.ipv6.conf.default.disable_ipv6=1 2>/dev/null || true
    ok "IPv6: disabled"

    # AppArmor: enforce browser profiles
    if command -v aa-enforce &>/dev/null; then
        aa-enforce /etc/apparmor.d/usr.bin.firefox-esr 2>/dev/null || true
        aa-enforce /etc/apparmor.d/usr.bin.firefox 2>/dev/null || true
        ok "AppArmor: browser profiles enforced"
    fi

    echo "private" > "$ATLAZES_MODE_FILE"
    echo ""
    ok "Mode set to: PRIVATE"
    info "MAC randomized, DNS encrypted, IPv6 disabled. IP address still visible to websites."
}

_set_mode_paranoid() {
    echo -e "${CYAN}${BOLD}── Switching to PARANOID Mode ───────────────────${NC}"
    echo ""

    mkdir -p "$ATLAZES_STATE_DIR"

    # Firewall: deny everything except Tor
    ufw --force reset
    ufw default deny incoming
    ufw default deny outgoing
    ufw default deny forward
    # Allow Tor bootstrap and operation
    ufw allow out 9001/tcp comment "Tor relay"
    ufw allow out 9030/tcp comment "Tor directory"
    ufw allow out 443/tcp  comment "HTTPS"
    ufw allow out 80/tcp   comment "HTTP (for Tor bootstrap)"
    # BUG FIX: Removed "ufw allow out 53/udp" — dnscrypt-proxy is on localhost,
    # not an external DNS server. Allowing outgoing UDP 53 would bypass the
    # intent of paranoid mode by allowing unencrypted DNS to external servers.
    # DNS is handled locally by dnscrypt-proxy → Tor.
    ufw allow out to 127.0.0.1 comment "Localhost"
    ufw allow out to ::1       comment "Localhost IPv6"
    ufw logging on
    ufw --force enable
    ok "Firewall: paranoid (deny all outgoing except Tor + HTTPS)"

    # Start Tor
    systemctl start tor 2>/dev/null || warn "Tor failed to start"
    systemctl enable tor 2>/dev/null || true
    ok "Tor: started (SOCKS5 on 127.0.0.1:9050)"

    # DNS: route through Tor (use Tor's DNS resolver)
    cat > /etc/resolv.conf << 'EOF'
# ATLAZES OS - Paranoid Mode: DNS via Tor
nameserver 127.0.0.1
options edns0
EOF
    ok "DNS: via local resolver (Tor)"

    # MAC: randomize all interfaces
    # BUG FIX: Same as private mode — avoid full down/up cycle
    if command -v macchanger &>/dev/null; then
        for iface in $(ip link show | grep "^[0-9]" | awk -F': ' '{print $2}' | grep -v lo | grep -v docker | grep -v veth); do
            macchanger -r "$iface" 2>/dev/null || true
        done
        ok "MAC: randomized (reconnect to network to apply)"
    else
        ok "MAC: will randomize on next connection (NetworkManager)"
    fi

    # Disable IPv6
    sysctl -w net.ipv6.conf.all.disable_ipv6=1 2>/dev/null || true
    sysctl -w net.ipv6.conf.default.disable_ipv6=1 2>/dev/null || true
    ok "IPv6: disabled"

    # AppArmor: enforce all stable profiles
    if command -v aa-enforce &>/dev/null; then
        for profile in /etc/apparmor.d/usr.bin.firefox* /etc/apparmor.d/usr.sbin.cups*; do
            [[ -f "$profile" ]] && aa-enforce "$profile" 2>/dev/null || true
        done
        ok "AppArmor: all stable profiles enforced"
    fi

    # Disable Bluetooth
    systemctl stop bluetooth 2>/dev/null || true
    rfkill block bluetooth 2>/dev/null || true
    ok "Bluetooth: disabled"

    # Clear DNS cache
    systemctl restart systemd-resolved 2>/dev/null || true
    ok "DNS cache: cleared"

    echo "paranoid" > "$ATLAZES_MODE_FILE"
    echo ""
    ok "Mode set to: PARANOID"
    warn "Tor routing active. Most outgoing traffic is blocked."
    warn "Most applications will not work. Use Tor Browser for browsing."
    warn "This mode significantly increases anonymity but does not guarantee it."
    warn "Tor has known limitations: traffic correlation, malicious exit nodes."
    info "To update packages first switch back: sudo atlazes mode normal"
    info "To restore normal mode: sudo atlazes mode normal"
}

# ─── COMMAND: tor ─────────────────────────────────────────────────────────────
cmd_tor() {
    local action="${1:-status}"
    need_root "tor $action"

    case "$action" in
        start)
            systemctl start tor
            ok "Tor started. SOCKS5 proxy: 127.0.0.1:9050"
            info "For anonymous browsing, use Tor Browser (torbrowser-launcher)"
            info "Configuring a regular browser to use this proxy does not provide"
            info "the same anonymity as Tor Browser — regular browsers leak identifying info."
            ;;
        stop)
            systemctl stop tor
            ok "Tor stopped."
            ;;
        status)
            systemctl status tor --no-pager
            ;;
        *)
            echo "Usage: sudo atlazes tor <start|stop|status>"
            ;;
    esac
}

# ─── COMMAND: dns ─────────────────────────────────────────────────────────────
cmd_dns() {
    echo -e "${CYAN}${BOLD}── DNS Configuration ────────────────────────────${NC}"
    echo ""
    echo "resolv.conf:"
    cat /etc/resolv.conf
    echo ""
    echo "dnscrypt-proxy status:"
    systemctl status dnscrypt-proxy --no-pager 2>/dev/null || echo "  Not installed."
    echo ""
    echo "DNS leak test:"
    if command -v dig &>/dev/null; then
        echo "  (Shows which resolver is responding — does not verify no-log policy)"
        dig +short TXT whoami.ds.akahelp.net 2>/dev/null || echo "  (no internet or dig unavailable)"
    fi
}

# ─── COMMAND: update ──────────────────────────────────────────────────────────
cmd_update() {
    need_root "update"
    echo -e "${CYAN}${BOLD}── System Update ────────────────────────────────${NC}"
    echo ""
    apt-get update
    apt-get upgrade -y
    apt-get dist-upgrade -y
    apt-get autoremove -y
    apt-get autoclean
    echo ""
    ok "System updated."
}

# ─── COMMAND: info ────────────────────────────────────────────────────────────
cmd_info() {
    echo -e "${CYAN}${BOLD}── System Information ───────────────────────────${NC}"
    echo ""
    if command -v neofetch &>/dev/null; then
        neofetch
    else
        uname -a
        cat /etc/os-release 2>/dev/null || true
        cat /etc/atlazes-release 2>/dev/null || true
    fi
}

# ─── COMMAND: logs ────────────────────────────────────────────────────────────
cmd_logs() {
    echo -e "${CYAN}${BOLD}── Security Logs ────────────────────────────────${NC}"
    echo ""
    echo "--- Auth log (last 20 lines) ---"
    sudo tail -20 /var/log/auth.log 2>/dev/null || \
        sudo journalctl _COMM=sshd --no-pager -n 20 2>/dev/null || \
        echo "  No auth log available."
    echo ""
    echo "--- UFW log (last 10 lines) ---"
    sudo tail -10 /var/log/ufw.log 2>/dev/null || \
        sudo journalctl -k --no-pager -n 10 2>/dev/null | grep -i "UFW\|BLOCK" || \
        echo "  No UFW log available."
    echo ""
    echo "--- Fail2ban (last 10 lines) ---"
    sudo tail -10 /var/log/fail2ban.log 2>/dev/null || \
        sudo journalctl -u fail2ban --no-pager -n 10 2>/dev/null || \
        echo "  No fail2ban log available."
}

# ─── COMMAND: help ────────────────────────────────────────────────────────────
cmd_help() {
    banner
    echo "Usage: atlazes <command> [options]"
    echo ""
    echo -e "${BOLD}Security:${NC}"
    echo "  status              Security and privacy component status"
    echo "  scan [path]         ClamAV signature-based malware scan"
    echo "  secure              Check and restore inactive security services"
    echo "  sandbox <app>       Launch app in Firejail (namespace+seccomp sandbox)"
    echo "  logs                Recent security log entries"
    echo ""
    echo -e "${BOLD}Privacy:${NC}"
    echo "  mode                Show current privacy posture"
    echo "  mode normal         Encrypted DNS, MAC random, firewall (IP visible)"
    echo "  mode private        Adds IPv6 off, immediate MAC random (IP visible)"
    echo "  mode paranoid       Tor routing, strict firewall (increased anonymity)"
    echo "  clean               Clean temp files and browser cache"
    echo "  dns                 Show DNS config and resolver test"
    echo "  tor <start|stop>    Control Tor daemon"
    echo ""
    echo -e "${BOLD}System:${NC}"
    echo "  update              Update system packages"
    echo "  info                System information"
    echo ""
    echo -e "${DIM}Note: ATLAZES OS reduces passive surveillance."
    echo "  It does not hide your IP address or provide anonymity."
    echo "  For anonymity, use Tails OS or Tor Browser.${NC}"
    echo ""
}

# ─── Main dispatcher ──────────────────────────────────────────────────────────
case "${1:-help}" in
    status)             cmd_status ;;
    scan)               cmd_scan "${2:-$HOME}" ;;
    clean)              cmd_clean ;;
    secure)             cmd_secure ;;
    sandbox)            shift; cmd_sandbox "$@" ;;
    mode)               cmd_mode "${2:-}" ;;
    tor)                cmd_tor "${2:-status}" ;;
    dns)                cmd_dns ;;
    update)             cmd_update ;;
    info)               cmd_info ;;
    logs)               cmd_logs ;;
    help|--help|-h)     cmd_help ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        echo "Run 'atlazes help' for usage."
        exit 1
        ;;
esac
