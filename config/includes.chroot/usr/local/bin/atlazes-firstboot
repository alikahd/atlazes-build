#!/bin/bash
# =============================================================================
# ATLAZES OS - First Boot Script
# يُشغَّل مرة واحدة عند أول إقلاع لتفعيل UFW وإعدادات الأمان
# =============================================================================

DONE_FILE="/var/lib/atlazes/.firstboot-done"

[[ -f "$DONE_FILE" ]] && exit 0

echo "[ATLAZES] First boot setup..."

# تعيين كلمة مرور المستخدم الحي (fallback إذا لم يعمل live-config)
# live-config يُنشئ المستخدم أثناء الإقلاع — نتأكد من كلمة المرور هنا
if id "atlazes" &>/dev/null; then
    echo "atlazes:atlazes" | chpasswd 2>/dev/null || true
    echo "root:atlazes" | chpasswd 2>/dev/null || true
    echo "[ATLAZES] Passwords set for atlazes and root."
fi

# تفعيل UFW الآن بعد أن يكون النظام جاهزاً
if command -v ufw &>/dev/null; then
    ufw --force enable 2>/dev/null || true
    echo "[ATLAZES] UFW enabled."
fi

# تحديث rkhunter database
if command -v rkhunter &>/dev/null; then
    rkhunter --propupd 2>/dev/null || true
fi

# تسجيل الانتهاء
mkdir -p /var/lib/atlazes
touch "$DONE_FILE"
echo "[ATLAZES] First boot complete."
