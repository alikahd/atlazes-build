#!/bin/bash
# =============================================================================
# ATLAZES OS - Hook: اختبار Xorg وإصلاح الشاشة السوداء
# يُنشئ سكريبت تشخيص يُشغَّل تلقائياً عند الإقلاع
# =============================================================================

set -euo pipefail

echo "[ATLAZES] إعداد اختبار Xorg..."

# ── سكريبت تشخيص يُشغَّل قبل LightDM ────────────────────────────────────────
cat > /usr/local/bin/atlazes-xorg-check << 'SCRIPT'
#!/bin/bash
# يُشغَّل من systemd قبل lightdm للتحقق من Xorg

LOG="/var/log/atlazes-xorg-check.log"
echo "=== ATLAZES Xorg Check $(date) ===" > "$LOG"

# فحص الدرايفرات المتاحة
echo "Available drivers:" >> "$LOG"
ls /usr/lib/xorg/modules/drivers/ 2>/dev/null >> "$LOG" || echo "  none found" >> "$LOG"

# فحص GPU
echo "GPU:" >> "$LOG"
lspci 2>/dev/null | grep -iE "vga|display|3d" >> "$LOG" || echo "  lspci unavailable" >> "$LOG"

# فحص framebuffer
echo "Framebuffer devices:" >> "$LOG"
ls /dev/fb* 2>/dev/null >> "$LOG" || echo "  none" >> "$LOG"

# فحص DRM
echo "DRM devices:" >> "$LOG"
ls /dev/dri/ 2>/dev/null >> "$LOG" || echo "  none" >> "$LOG"

# اختبار Xorg مباشرة
echo "Testing Xorg..." >> "$LOG"
timeout 5 Xorg -noreset -logverbose 6 :99 -config /dev/null >> "$LOG" 2>&1 &
XPID=$!
sleep 3
if kill -0 $XPID 2>/dev/null; then
    echo "Xorg started successfully on :99" >> "$LOG"
    kill $XPID 2>/dev/null
else
    echo "Xorg failed to start" >> "$LOG"
    # محاولة مع fbdev صريح
    echo "Trying with fbdev..." >> "$LOG"
    timeout 5 Xorg -noreset :99 -config /etc/X11/xorg.conf.d/99-atlazes-fallback.conf >> "$LOG" 2>&1 &
    XPID=$!
    sleep 3
    kill $XPID 2>/dev/null
fi

echo "Check complete. See $LOG" >> "$LOG"
SCRIPT

chmod +x /usr/local/bin/atlazes-xorg-check

# ── إنشاء xorg.conf fallback لـ fbdev ────────────────────────────────────────
# يُستخدم كـ fallback إذا فشل الكشف التلقائي
cat > /etc/X11/xorg.conf.d/99-atlazes-fallback.conf << 'EOF'
# ATLAZES OS - Xorg fbdev fallback configuration
# يُستخدم فقط إذا فشل الكشف التلقائي

Section "Device"
    Identifier  "Fallback fbdev"
    Driver      "fbdev"
EndSection
EOF

# ── إنشاء systemd service للتشخيص ────────────────────────────────────────────
cat > /etc/systemd/system/atlazes-xorg-check.service << 'EOF'
[Unit]
Description=ATLAZES Xorg Compatibility Check
Before=lightdm.service
After=systemd-udev-settle.service

[Service]
Type=oneshot
ExecStart=/usr/local/bin/atlazes-xorg-check
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
EOF

systemctl enable atlazes-xorg-check.service 2>/dev/null || true

# ── إضافة getty على tty2 كـ fallback إذا فشل LightDM ─────────────────────────
# إذا كانت الشاشة سوداء، يمكن الضغط Ctrl+Alt+F2 للوصول لـ terminal
systemctl enable getty@tty2.service 2>/dev/null || true

# ── إنشاء سكريبت إصلاح طارئ يُشغَّل من terminal ─────────────────────────────
cat > /usr/local/bin/atlazes-fix-display << 'FIXSCRIPT'
#!/bin/bash
# تشغيل هذا السكريبت من tty2 إذا كانت الشاشة سوداء:
# Ctrl+Alt+F2 → login: atlazes / atlazes → sudo atlazes-fix-display

echo "=== ATLAZES Display Fix ==="
echo "Checking display environment..."

# محاولة 1: تشغيل XFCE4 مباشرة بدون LightDM
echo "Attempt 1: Direct XFCE4 launch..."
if DISPLAY=:0 xfce4-session 2>/dev/null &
then
    echo "XFCE4 started on :0"
    exit 0
fi

# محاولة 2: تشغيل Xorg مع fbdev ثم XFCE4
echo "Attempt 2: Xorg with fbdev..."
Xorg :0 -config /etc/X11/xorg.conf.d/99-atlazes-fallback.conf &
sleep 3
DISPLAY=:0 startxfce4 &
echo "Started. Check display."

# محاولة 3: إعادة تشغيل LightDM
echo "Attempt 3: Restart LightDM..."
systemctl restart lightdm
FIXSCRIPT

chmod +x /usr/local/bin/atlazes-fix-display

echo "[ATLAZES] اكتمل إعداد اختبار Xorg."
