    def _make_status_card(self, title, value, subtitle):
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        card.get_style_context().add_class("card")
        t = Gtk.Label(label=title)
        t.get_style_context().add_class("card-title")
        t.set_halign(Gtk.Align.START)
        v = Gtk.Label(label=value)
        v.get_style_context().add_class("metric-value")
        v.set_halign(Gtk.Align.CENTER)
        s = Gtk.Label(label=subtitle)
        s.get_style_context().add_class("metric-label")
        s.set_halign(Gtk.Align.CENTER)
        card.pack_start(t, False, False, 2)
        card.pack_start(v, True, True, 8)
        card.pack_start(s, False, False, 2)
        return card, v

    def refresh_data(self):
        threading.Thread(target=self._fetch_data, daemon=True).start()
        return True

    def _fetch_data(self):
        # Firewall
        fw = run_cmd("ufw status 2>/dev/null | head -1 | awk '{print $2}'", "unknown")
        fw_ok = fw.lower() == "active"

        # AppArmor
        aa = run_cmd("systemctl is-active apparmor 2>/dev/null", "inactive")
        aa_ok = aa == "active"

        # Tor
        tor = run_cmd("systemctl is-active tor 2>/dev/null", "inactive")
        tor_ok = tor == "active"

        # DNS
        dns = run_cmd("grep nameserver /etc/resolv.conf 2>/dev/null | head -1 | awk '{print $2}'", "default")

        # Mode
        mode = run_cmd("cat /var/lib/atlazus/current-mode 2>/dev/null", "normal")

        # System info
        hostname = run_cmd("hostname", "atlazus")
        kernel   = run_cmd("uname -r", "unknown")
        uptime   = run_cmd("uptime -p 2>/dev/null || uptime", "unknown")
        mem      = run_cmd("free -h | awk '/^Mem:/{print $3\"/\"$2}'", "unknown")
        cpu      = run_cmd("grep 'model name' /proc/cpuinfo | head -1 | cut -d: -f2 | xargs", "unknown")

        # Network
        iface = run_cmd("ip -o link show | awk -F': ' '$2!=\"lo\"{print $2;exit}'", "")
        mac   = run_cmd(f"cat /sys/class/net/{iface}/address 2>/dev/null", "unknown") if iface else "unknown"
        ip4   = run_cmd(f"ip -4 addr show {iface} 2>/dev/null | grep inet | awk '{{print $2}}'", "none") if iface else "none"

        # Security score
        score = 0
        checks = []
        if fw_ok:   score += 25; checks.append("✓ Firewall")
        else:       checks.append("✗ Firewall")
        if aa_ok:   score += 25; checks.append("✓ AppArmor")
        else:       checks.append("✗ AppArmor")
        if dns not in ["8.8.8.8", "1.1.1.1", "default"]: score += 25; checks.append("✓ Private DNS")
        else:       checks.append("✗ Private DNS")
        if tor_ok:  score += 25; checks.append("✓ Tor")
        else:       checks.append("✗ Tor")

        GLib.idle_add(self._update_ui,
            fw, fw_ok, aa, aa_ok, tor, tor_ok, dns,
            mode, hostname, kernel, uptime, mem, cpu,
            iface, mac, ip4, score, checks)

    def _update_ui(self, fw, fw_ok, aa, aa_ok, tor, tor_ok, dns,
                   mode, hostname, kernel, uptime, mem, cpu,
                   iface, mac, ip4, score, checks):
        # Status cards
        self.fw_card[1].set_text("ACTIVE" if fw_ok else "INACTIVE")
        self.fw_card[1].get_style_context().remove_class("status-ok")
        self.fw_card[1].get_style_context().remove_class("status-err")
        self.fw_card[1].get_style_context().add_class("status-ok" if fw_ok else "status-err")

        self.aa_card[1].set_text("ACTIVE" if aa_ok else "INACTIVE")
        self.aa_card[1].get_style_context().remove_class("status-ok")
        self.aa_card[1].get_style_context().remove_class("status-err")
        self.aa_card[1].get_style_context().add_class("status-ok" if aa_ok else "status-warn")

        self.tor_card[1].set_text("ACTIVE" if tor_ok else "INACTIVE")
        self.tor_card[1].get_style_context().remove_class("status-ok")
        self.tor_card[1].get_style_context().remove_class("status-warn")
        self.tor_card[1].get_style_context().add_class("status-ok" if tor_ok else "status-warn")

        self.dns_card[1].set_text(dns[:15] if dns else "default")

        # Mode badge
        mode_colors = {"normal": "#3fb950", "privacy": "#d29922", "stealth": "#f85149"}
        color = mode_colors.get(mode, "#00d4ff")
        self.mode_label.set_text(f"● {mode.upper()}")

        # System info
        self.sys_info_label.set_text(
            f"Host:    {hostname}\n"
            f"Kernel:  {kernel}\n"
            f"Uptime:  {uptime}\n"
            f"Memory:  {mem}\n"
            f"CPU:     {cpu[:40] if cpu else 'unknown'}"
        )

        # Network
        self.net_label.set_text(
            f"Interface: {iface or 'none'}\n"
            f"IP:        {ip4 or 'none'}\n"
            f"MAC:       {mac}\n"
            f"DNS:       {dns}"
        )

        # Score
        if score >= 75:
            self.score_label.set_text(f"{score}/100")
            self.score_label.get_style_context().remove_class("status-warn")
            self.score_label.get_style_context().remove_class("status-err")
            self.score_label.get_style_context().add_class("status-ok")
            self.score_desc.set_text("Good Security")
        elif score >= 50:
            self.score_label.set_text(f"{score}/100")
            self.score_label.get_style_context().add_class("status-warn")
            self.score_desc.set_text("Moderate Security")
        else:
            self.score_label.set_text(f"{score}/100")
            self.score_label.get_style_context().add_class("status-err")
            self.score_desc.set_text("Low Security")

        self.statusbar.set_text(f"Last updated: {time.strftime('%H:%M:%S')}  |  Mode: {mode}")
        return False

    def _run_terminal(self, cmd):
        subprocess.Popen(
            ["xfce4-terminal", "--title", "ATLAZUS", "--hold", "-e",
             f"bash -c '{cmd}; echo; echo Press Enter; read'"],
            start_new_session=True
        )

    def on_fw_on(self, btn):
        self._run_terminal("sudo ufw --force enable && sudo ufw status verbose")
    def on_fw_off(self, btn):
        self._run_terminal("sudo ufw disable")
    def on_privacy(self, btn):
        self._run_terminal("sudo atlazus-mode privacy")
    def on_stealth(self, btn):
        self._run_terminal("sudo atlazus-mode stealth")
    def on_normal(self, btn):
        self._run_terminal("sudo atlazus-mode normal")
    def on_tor_on(self, btn):
        self._run_terminal("sudo systemctl start tor && systemctl status tor --no-pager")
    def on_tor_off(self, btn):
        self._run_terminal("sudo systemctl stop tor && echo Tor stopped")
    def on_update(self, btn):
        self._run_terminal("sudo apt update && sudo apt upgrade -y")

if __name__ == "__main__":
    app = AtlazusDashboard()
    app.connect("destroy", Gtk.main_quit)
    Gtk.main()
