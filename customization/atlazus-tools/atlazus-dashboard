        self.fw_card   = self._make_status_card("🔒 Firewall", "Checking...", "UFW Status")
        self.aa_card   = self._make_status_card("🛡️ AppArmor", "Checking...", "MAC Status")
        self.tor_card  = self._make_status_card("🧅 Tor", "Checking...", "Anonymity")
        self.dns_card  = self._make_status_card("🌐 DNS", "Checking...", "Privacy DNS")

        row1.pack_start(self.fw_card[0],  True, True, 0)
        row1.pack_start(self.aa_card[0],  True, True, 0)
        row1.pack_start(self.tor_card[0], True, True, 0)
        row1.pack_start(self.dns_card[0], True, True, 0)

        # Row 2: System Info + Quick Actions
        row2 = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
        content.pack_start(row2, False, False, 0)

        # System Info Card
        sys_card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        sys_card.get_style_context().add_class("card")
        sys_title = Gtk.Label(label="💻 SYSTEM INFO")
        sys_title.get_style_context().add_class("card-title")
        sys_title.set_halign(Gtk.Align.START)
        sys_card.pack_start(sys_title, False, False, 4)

        self.sys_info_label = Gtk.Label(label="Loading...")
        self.sys_info_label.set_halign(Gtk.Align.START)
        self.sys_info_label.set_line_wrap(True)
        self.sys_info_label.override_color(
            Gtk.StateFlags.NORMAL, Gdk.RGBA(0.788, 0.820, 0.851, 1))
        sys_card.pack_start(self.sys_info_label, True, True, 4)

