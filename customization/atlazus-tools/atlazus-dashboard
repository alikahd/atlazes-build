        title.get_style_context().add_class("title")
        title.set_halign(Gtk.Align.START)
        subtitle = Gtk.Label(label="Security Dashboard — Version 2.0 (Horizon)")
        subtitle.get_style_context().add_class("subtitle")
        subtitle.set_halign(Gtk.Align.START)
        title_box.pack_start(title, False, False, 0)
        title_box.pack_start(subtitle, False, False, 0)

        self.mode_label = Gtk.Label(label="● NORMAL")
        self.mode_label.get_style_context().add_class("mode-badge")

        header.pack_start(title_box, True, True, 0)
        header.pack_end(self.mode_label, False, False, 0)
        main_box.pack_start(header, False, False, 0)

        # Scrollable content
        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        content = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        content.set_margin_start(12)
        content.set_margin_end(12)
        content.set_margin_top(12)
        content.set_margin_bottom(12)
        scroll.add(content)
        main_box.pack_start(scroll, True, True, 0)

