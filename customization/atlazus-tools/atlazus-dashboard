        actions_card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL)
        actions_card.get_style_context().add_class("card")
        act_title = Gtk.Label(label="⚡ QUICK ACTIONS")
        act_title.get_style_context().add_class("card-title")
        act_title.set_halign(Gtk.Align.START)
        actions_card.pack_start(act_title, False, False, 4)

