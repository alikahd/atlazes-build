#!/bin/bash
# =============================================================================
# ATLAZUS OS - VirtualBox Guest Additions Auto-Setup
# يُشغَّل تلقائياً عند الإقلاع في VirtualBox
# =============================================================================

log() { echo "[ATLAZUS-VBOX] $*"; }

# التحقق من أننا داخل VirtualBox
is_virtualbox() {
    dmidecode -s system-product-name 2>/dev/null | grep -qi "virtualbox" && return 0
    lspci 2>/dev/null | grep -qi "virtualbox" && return 0
    cat /sys/class/dmi/id/product_name 2>/dev/null | grep -qi "virtualbox" && return 0
    return 1
}

is_virtualbox || { log "Not running in VirtualBox, skipping."; exit 0; }

log "VirtualBox detected — setting up Guest Additions..."

# virtualbox-guest-utils غير موجود في Trixie الرسمي
# الحل: تثبيت من ISO المرفق مع VirtualBox (الأكثر موثوقية)

# محاولة 1: من ISO المرفق مع VirtualBox (/dev/cdrom)
if [[ -b /dev/cdrom ]] || [[ -b /dev/sr0 ]]; then
    CDROM="/dev/cdrom"
    [[ -b /dev/sr0 ]] && CDROM="/dev/sr0"
    mkdir -p /mnt/vbox-ga
    if mount "$CDROM" /mnt/vbox-ga 2>/dev/null; then
        if [[ -f /mnt/vbox-ga/VBoxLinuxAdditions.run ]]; then
            log "Installing from VirtualBox ISO..."
            apt-get install -y --no-install-recommends \
                build-essential dkms \
                linux-headers-$(uname -r) 2>/dev/null || true
            bash /mnt/vbox-ga/VBoxLinuxAdditions.run --nox11 2>/dev/null || true
            log "✓ Guest Additions installed from ISO"
        fi
        umount /mnt/vbox-ga 2>/dev/null || true
    fi
fi

# محاولة 2: تثبيت open-vm-tools كبديل (يعمل مع VirtualBox أيضاً)
if ! command -v VBoxClient &>/dev/null; then
    log "Trying open-vm-tools as fallback..."
    apt-get update -qq 2>/dev/null || true
    apt-get install -y --no-install-recommends \
        open-vm-tools \
        open-vm-tools-desktop \
        2>/dev/null || true
fi

# إضافة المستخدم لمجموعة vboxsf
if getent group vboxsf &>/dev/null; then
    usermod -aG vboxsf atlazus 2>/dev/null || true
fi

# تشغيل VBoxClient إذا كان متاحاً
if command -v VBoxClient &>/dev/null; then
    VBoxClient --clipboard    2>/dev/null || true
    VBoxClient --draganddrop  2>/dev/null || true
    VBoxClient --seamless     2>/dev/null || true
    VBoxClient --display      2>/dev/null || true
    log "✓ VBoxClient services started"
fi

# تحسين الأداء في VirtualBox بدون Guest Additions
# تعطيل compositor لأداء أفضل
if command -v xfconf-query &>/dev/null; then
    xfconf-query -c xfwm4 -p /general/use_compositing -s false 2>/dev/null || true
fi

log "VirtualBox setup complete."
