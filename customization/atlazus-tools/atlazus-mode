#!/bin/bash
# =============================================================================
# ATLAZUS OS - Privacy Modes
# atlazus mode [normal|privacy|stealth|status]
# =============================================================================

MODE_FILE="/var/lib/atlazus/current-mode"
mkdir -p /var/lib/atlazus

CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BOLD='\033[1m'
NC='\033[0m'

show_status() {
    local mode
    mode=$(cat "$MODE_FILE" 2>/dev/null || echo "normal")
    echo -e "${CYAN}${BOLD}ATLAZUS OS - Current Mode: ${mode^^}${NC}"
    echo ""
    echo -e "  Firewall : $(sudo ufw status 2>/dev/null | head -1 || echo 'unknown')"
    echo -e "  Tor      : $(systemctl is-active tor 2>/dev/null || echo 'inactive')"
    echo -e "  DNS      : $(grep nameserver /etc/resolv.conf 2>/dev/null | head -1 | awk '{print $2}' || echo 'default')"
    echo ""
}

set_normal() {
    echo -e "${GREEN}[+]${NC} Switching to NORMAL mode..."
    sudo systemctl stop tor 2>/dev/null || true
    echo "normal" | sudo tee "$MODE_FILE" > /dev/null
    echo -e "${GREEN}[✓]${NC} Normal mode active."
}

set_privacy() {
    echo -e "${YELLOW}[+]${NC} Switching to PRIVACY mode..."
    # MAC randomization
    IFACE=$(ip -o link show 2>/dev/null | awk -F': ' '$2 != "lo" {print $2; exit}')
    if [[ -n "$IFACE" ]] && command -v macchanger &>/dev/null; then
        sudo ip link set "$IFACE" down 2>/dev/null || true
        sudo macchanger -r "$IFACE" 2>/dev/null || true
        sudo ip link set "$IFACE" up 2>/dev/null || true
        echo -e "${GREEN}[✓]${NC} MAC randomized on $IFACE"
    fi
    # DNS privacy
    sudo tee /etc/resolv.conf > /dev/null << 'DNS'
nameserver 9.9.9.9
nameserver 149.112.112.112
DNS
    echo -e "${GREEN}[✓]${NC} DNS set to Quad9"
    echo "privacy" | sudo tee "$MODE_FILE" > /dev/null
    echo -e "${GREEN}[✓]${NC} Privacy mode active."
}

set_stealth() {
    echo -e "${RED}[+]${NC} Switching to STEALTH mode..."
    set_privacy
    # Start Tor
    if command -v tor &>/dev/null; then
        sudo systemctl start tor 2>/dev/null || true
        sleep 2
        if systemctl is-active tor &>/dev/null; then
            echo -e "${GREEN}[✓]${NC} Tor started"
            # Route DNS through Tor
            sudo tee /etc/resolv.conf > /dev/null << 'DNS'
nameserver 127.0.0.1
DNS
        fi
    fi
    echo "stealth" | sudo tee "$MODE_FILE" > /dev/null
    echo -e "${RED}[✓]${NC} Stealth mode active — all traffic through Tor."
    echo -e "${YELLOW}[!]${NC} Note: Configure applications to use SOCKS5 127.0.0.1:9050"
}

case "${1:-status}" in
    status)       show_status ;;
    normal)       set_normal ;;
    privacy)      set_privacy ;;
    stealth)      set_stealth ;;
    *)
        echo "Usage: atlazus mode [normal|privacy|stealth|status]"
        echo ""
        echo "  normal   — Default settings"
        echo "  privacy  — MAC random + DNS Quad9"
        echo "  stealth  — Privacy + Tor routing"
        echo "  status   — Show current mode"
        ;;
esac
