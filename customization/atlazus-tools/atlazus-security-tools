CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BOLD='\033[1m'
NC='\033[0m'

TOOLS_DIR="/opt/atlazus-tools"

log()  { echo -e "${GREEN}[+]${NC} $*"; }
warn() { echo -e "${YELLOW}[!]${NC} $*"; }
err()  { echo -e "${RED}[✗]${NC} $*"; }

# ── تثبيت التبعيات الأساسية ───────────────────────────────────────────────────
install_base_deps() {
    log "Installing base dependencies..."
    sudo apt-get update -qq
    sudo apt-get install -y \
        git python3 python3-pip python3-venv \
        aircrack-ng iw wireless-tools \
        macchanger net-tools curl wget \
        hostapd dnsmasq nmap \
        hcxdumptool hcxtools \
        hashcat john \
        2>/dev/null || true
    sudo mkdir -p "$TOOLS_DIR"
    log "Base dependencies installed."
}

# ── Wifite2 ───────────────────────────────────────────────────────────────────
install_wifite() {
    log "Installing Wifite2..."
    sudo apt-get install -y wifite 2>/dev/null || {
        # من GitHub إذا لم يكن في المستودع
        sudo git clone https://github.com/derv82/wifite2.git "$TOOLS_DIR/wifite2" 2>/dev/null || \
        sudo git -C "$TOOLS_DIR/wifite2" pull 2>/dev/null || true
        sudo ln -sf "$TOOLS_DIR/wifite2/Wifite.py" /usr/local/bin/wifite 2>/dev/null || true
        sudo chmod +x "$TOOLS_DIR/wifite2/Wifite.py" 2>/dev/null || true
    }
    echo ""
    echo -e "  ${BOLD}Wifite2${NC} — Automated WiFi auditing"
    echo "  Usage: sudo wifite"
    echo "  • Auto-attacks WEP, WPA, WPS"
    echo "  • Captures handshakes automatically"
    echo "  • Supports PMKID attacks"
}

