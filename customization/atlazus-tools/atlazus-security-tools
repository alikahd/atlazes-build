# ── Bettercap ─────────────────────────────────────────────────────────────────
install_bettercap() {
    log "Installing Bettercap..."
    sudo apt-get install -y bettercap 2>/dev/null || {
        # من GitHub releases
        local ARCH="amd64"
        local LATEST
        LATEST=$(curl -s https://api.github.com/repos/bettercap/bettercap/releases/latest \
            | grep "browser_download_url.*linux_${ARCH}" \
            | cut -d '"' -f 4 | head -1)
        if [[ -n "$LATEST" ]]; then
            wget -q "$LATEST" -O /tmp/bettercap.zip
            sudo unzip -o /tmp/bettercap.zip -d /usr/local/bin/ bettercap 2>/dev/null || true
            sudo chmod +x /usr/local/bin/bettercap
            rm -f /tmp/bettercap.zip
        fi
    }
    # تحميل caplets
    sudo bettercap -eval "caplets.update; quit" 2>/dev/null || true

    echo ""
    echo -e "  ${BOLD}Bettercap${NC} — Network attack & monitoring framework"
    echo "  Usage: sudo bettercap -iface wlan0"
    echo "  • ARP spoofing / MITM"
    echo "  • WiFi scanning and deauth"
    echo "  • BLE scanning"
    echo "  • HTTP/HTTPS sniffing"
    echo "  • DNS spoofing"
}

# ── Evil-WPA / Hostapd-WPE ────────────────────────────────────────────────────
install_evil_ap() {
    log "Installing Evil AP tools..."
    sudo apt-get install -y \
        hostapd dnsmasq \
        2>/dev/null || true

    # hostapd-wpe
    sudo git clone https://github.com/OpenSecurityResearch/hostapd-wpe.git \
        "$TOOLS_DIR/hostapd-wpe" 2>/dev/null || \
    sudo git -C "$TOOLS_DIR/hostapd-wpe" pull 2>/dev/null || true

    # create_ap (أداة سهلة لإنشاء AP)
    sudo git clone https://github.com/oblique/create_ap.git \
        "$TOOLS_DIR/create_ap" 2>/dev/null || \
    sudo git -C "$TOOLS_DIR/create_ap" pull 2>/dev/null || true
    sudo make -C "$TOOLS_DIR/create_ap" install 2>/dev/null || true

    echo ""
    echo -e "  ${BOLD}Evil AP Tools${NC}"
    echo "  • hostapd-wpe: WPA Enterprise attacks"
    echo "  • create_ap: Easy AP creation"
    echo "  Usage: sudo create_ap wlan0 eth0 'FreeWiFi'"
}

# ── Hashcat + Rules ───────────────────────────────────────────────────────────
install_hashcat_full() {
    log "Installing Hashcat + wordlists + rules..."
    sudo apt-get install -y hashcat hashcat-utils 2>/dev/null || true

    # rockyou
    if [[ ! -f /usr/share/wordlists/rockyou.txt ]]; then
        [[ -f /usr/share/wordlists/rockyou.txt.gz ]] && \
            sudo gunzip /usr/share/wordlists/rockyou.txt.gz 2>/dev/null || true
    fi

    # SecLists
    if [[ ! -d /usr/share/seclists ]]; then
        log "Downloading SecLists (large download ~1GB)..."
        sudo git clone --depth 1 \
            https://github.com/danielmiessler/SecLists.git \
            /usr/share/seclists 2>/dev/null || true
    fi

    # Hashcat rules
    sudo mkdir -p /usr/share/hashcat-rules
    sudo git clone https://github.com/NotSoSecure/password_cracking_rules.git \
        /usr/share/hashcat-rules/NotSoSecure 2>/dev/null || true

    echo ""
    echo -e "  ${BOLD}Hashcat + Wordlists${NC}"
    echo "  Wordlists: /usr/share/wordlists/"
    echo "  SecLists:  /usr/share/seclists/"
    echo "  Usage: hashcat -m 22000 capture.hc22000 /usr/share/wordlists/rockyou.txt"
    echo "  Convert: hcxpcapngtool capture.pcapng -o capture.hc22000"
}

# ── Wireshark + Bettercap + MITMf ────────────────────────────────────────────
install_mitm_tools() {
    log "Installing MITM tools..."
    sudo apt-get install -y \
        wireshark tshark \
        ettercap-graphical \
        arpwatch \
        sslstrip \
        mitmproxy \
        2>/dev/null || true

    # MITMf
    sudo git clone https://github.com/byt3bl33d3r/MITMf.git \
        "$TOOLS_DIR/MITMf" 2>/dev/null || \
    sudo git -C "$TOOLS_DIR/MITMf" pull 2>/dev/null || true

    # إضافة المستخدم لمجموعة wireshark
    sudo usermod -aG wireshark "$USER" 2>/dev/null || true

    echo ""
    echo -e "  ${BOLD}MITM Tools${NC}"
    echo "  • wireshark: Packet capture GUI"
    echo "  • ettercap: ARP poisoning + sniffing"
    echo "  • mitmproxy: HTTP/HTTPS proxy"
