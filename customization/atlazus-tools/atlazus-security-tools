}

# ── Nmap + Masscan + Recon ────────────────────────────────────────────────────
install_recon_full() {
    log "Installing Recon tools..."
    sudo apt-get install -y \
        nmap masscan \
        nikto dirb gobuster \
        sqlmap \
        whatweb wafw00f \
        theharvester \
        dnsenum dnsrecon \
        whois \
        2>/dev/null || true

    # Subfinder
    if command -v go &>/dev/null; then
        go install -v github.com/projectdiscovery/subfinder/v2/cmd/subfinder@latest 2>/dev/null || true
    fi

    echo ""
    echo -e "  ${BOLD}Recon Tools${NC}"
    echo "  • nmap: Port scanning"
    echo "  • nikto: Web vulnerability scanner"
    echo "  • sqlmap: SQL injection"
    echo "  • gobuster: Directory brute force"
    echo "  • theharvester: OSINT"
}

# ── Metasploit ────────────────────────────────────────────────────────────────
install_metasploit() {
    log "Installing Metasploit Framework..."
    if ! command -v msfconsole &>/dev/null; then
        # تثبيت من المستودع الرسمي
        curl -fsSL https://apt.metasploit.com/metasploit-framework.gpg.key \
            | sudo gpg --dearmor -o /usr/share/keyrings/metasploit.gpg 2>/dev/null || true
        echo "deb [signed-by=/usr/share/keyrings/metasploit.gpg] https://apt.metasploit.com/ focal main" \
            | sudo tee /etc/apt/sources.list.d/metasploit.list > /dev/null
        sudo apt-get update -qq
        sudo apt-get install -y metasploit-framework 2>/dev/null || true
    fi

    echo ""
    echo -e "  ${BOLD}Metasploit Framework${NC}"
    echo "  Usage: msfconsole"
    echo "  • search <exploit>"
    echo "  • use exploit/..."
    echo "  • set RHOSTS target"
    echo "  • run"
}

# ── تثبيت الكل ───────────────────────────────────────────────────────────────
install_all() {
    echo -e "${RED}${BOLD}Installing ALL tools — this may take 20-40 minutes${NC}"
    install_base_deps
    install_wifite
    install_airgeddon
    install_fluxion
    install_bettercap
    install_evil_ap
    install_hashcat_full
    install_mitm_tools
    install_recon_full
    install_metasploit
