#!/bin/bash
# =============================================================================
# ATLAZUS OS — Main CLI v2.1
# =============================================================================

VERSION="2.0 (Horizon)"
BASE="Debian 13 (Trixie)"

CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

print_banner() {
    echo -e "${CYAN}${BOLD}"
    echo "  ╔══════════════════════════════════════════╗"
    echo "  ║              ATLAZUS OS                   ║"
    echo "  ║      Secure · Private · Professional      ║"
    echo "  ╚══════════════════════════════════════════╝"
    echo -e "${NC}"
}

show_help() {
    print_banner
    cat << EOF
${BOLD}Usage:${NC} atlazus <command> [args...]

${BOLD}Commands:${NC}
  info, status     System information and security status
  version          Show version
  update           Update system (apt update + upgrade)
  mode <mode>      Switch privacy mode (normal/privacy/stealth/status)
  firewall <args>  Manage firewall (on/off/status/allow/deny)
  privacy <args>   Privacy tools (mac-random/dns/tor/status)
  control          Open graphical Control Center
  welcome          Show welcome screen
  security [cat]   Install security/pentesting tools
  dashboard        Open security dashboard (GTK)
  post-install     Run post-install setup (after installing to disk)
  help             Show this help

${BOLD}Examples:${NC}
  atlazus info
  atlazus mode privacy
  atlazus mode stealth
  atlazus firewall status
  atlazus privacy tor on
  atlazus control

EOF
}

cmd_info() {
    print_banner
    echo -e "${BOLD}System:${NC}     ATLAZUS OS ${VERSION}"
    echo -e "${BOLD}Base:${NC}       ${BASE}"
    echo -e "${BOLD}Kernel:${NC}     $(uname -r)"
    echo -e "${BOLD}Hostname:${NC}   $(hostname)"
    echo -e "${BOLD}Uptime:${NC}     $(uptime -p 2>/dev/null || uptime)"
    echo ""
    echo -e "${BOLD}── Security Status ──────────────────────────${NC}"
    echo -e "  Firewall  : $(sudo -n ufw status 2>/dev/null | head -1 || echo 'run: sudo ufw status')"
    echo -e "  AppArmor  : $(systemctl is-active apparmor 2>/dev/null || echo 'unknown')"
    echo -e "  Tor       : $(systemctl is-active tor 2>/dev/null || echo 'inactive')"
    echo -e "  Mode      : $(cat /var/lib/atlazus/current-mode 2>/dev/null || echo 'normal')"
    echo ""
    echo -e "${BOLD}── Privacy Status ───────────────────────────${NC}"
    echo -e "  DNS       : $(grep nameserver /etc/resolv.conf 2>/dev/null | head -1 | awk '{print $2}' || echo 'default')"
    IFACE=$(ip -o link show 2>/dev/null | awk -F': ' '$2 != "lo" {print $2; exit}')
    [[ -n "$IFACE" ]] && echo -e "  MAC ($IFACE): $(cat /sys/class/net/$IFACE/address 2>/dev/null || echo 'unknown')"
    echo ""
}

case "${1:-help}" in
    info|status)      cmd_info ;;
    version|--version|-v) echo "ATLAZUS OS ${VERSION}" ;;
    update|upgrade)
        echo -e "${GREEN}[+]${NC} Updating system..."
        sudo apt-get update && sudo apt-get upgrade -y
        ;;
    mode)
        shift
        if command -v atlazus-mode &>/dev/null; then
            atlazus-mode "$@"
        else
            echo "atlazus-mode not found" >&2; exit 1
        fi
        ;;
    firewall|fw)
        shift
        if command -v atlazus-firewall &>/dev/null; then
            atlazus-firewall "$@"
        else
            echo "atlazus-firewall not found" >&2; exit 1
        fi
        ;;
    privacy)
        shift
        if command -v atlazus-privacy &>/dev/null; then
            atlazus-privacy "$@"
        else
            echo "atlazus-privacy not found" >&2; exit 1
        fi
        ;;
    control)
        if command -v atlazus-control &>/dev/null; then
            atlazus-control
        else
            echo "atlazus-control not found" >&2; exit 1
        fi
        ;;
    welcome)
        if command -v atlazus-welcome &>/dev/null; then
            rm -f "$HOME/.atlazus-welcome-shown"
            atlazus-welcome
        fi
        ;;
    security|sec|pentest)
        shift
        if command -v atlazus-security-tools &>/dev/null; then
            atlazus-security-tools "$@"
        else
            echo "atlazus-security-tools not found" >&2; exit 1
        fi
        ;;
    dashboard|dash)
        if command -v atlazus-dashboard &>/dev/null; then
            atlazus-dashboard &
        else
            echo "atlazus-dashboard not found" >&2; exit 1
        fi
        ;;
    post-install|postinstall)
        if command -v atlazus-post-install &>/dev/null; then
            atlazus-post-install
        else
            echo "atlazus-post-install not found" >&2; exit 1
        fi
        ;;
    help|--help|-h|"") show_help ;;
    *)
        echo "Unknown command: $1" >&2
        show_help >&2
        exit 1
        ;;
esac
